# Database — MySQL / MariaDB
# Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="mysql://root:password@localhost:3306/prajavarta"

# JWT secret — use a long random string in production
JWT_SECRET="change-me-to-a-long-random-string-in-production"

# Cron secret — protects /api/cron/score endpoint
CRON_SECRET="change-me-cron-secret"

# App
NEXT_PUBLIC_APP_NAME="Prajavarta"
NEXT_PUBLIC_API_URL="http://localhost:3000"

# GeoLite2 — download from https://dev.maxmind.com/geoip/geolite2-free-geolocation-data
# Place the .mmdb file on the server and set the path here
GEOLITE2_PATH="/opt/GeoLite2-City.mmdb"

# Claude API (for AI tagger — Phase 2, optional)
# ANTHROPIC_API_KEY="sk-ant-..."
